<Window x:Class="Gplx.WpfApp.SyncResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dữ liệu trên DB đích" Width="900" Height="580"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        FontSize="12">
    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F9FF"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
    </Window.Resources>
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"
                   TextTrimming="CharacterEllipsis">
            <Run Text="Dữ liệu trên DB đích - Khóa học:"/>
            <Run x:Name="txtCourseCode" FontWeight="Bold" Foreground="#0078D4"/>
        </TextBlock>
        <TabControl Grid.Row="1">
            <TabItem Header="Khóa học">
                <DataGrid x:Name="dgKhoaHoc"/>
            </TabItem>
            <TabItem Header="Học viên">
                <DataGrid x:Name="dgHocVien"/>
            </TabItem>
            <TabItem Header="Báo cáo I">
                <DataGrid x:Name="dgBaoCaoI"/>
            </TabItem>
            <TabItem Header="Báo cáo II">
                <DataGrid x:Name="dgBaoCaoII"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
