<Window x:Class="Gplx.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gplx - Đồng bộ dữ liệu" Width="800" Height="600"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="tabControl">
            <TabItem Header="Đồng bộ DB Sở">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Source / Dest groupboxes -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="Nguồn (Source)" Padding="6" Margin="0,0,4,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Row="0" Grid.Column="0" Content="Server:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtSoSrcServer" Text="." Margin="2"/>
                                <Button Grid.Row="0" Grid.Column="2" x:Name="btnSoTestSrc" Content="Kiểm tra" Margin="2" Padding="4,0" Click="BtnSoTestSrc_Click"/>
                                <Label Grid.Row="1" Grid.Column="0" Content="User:"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtSoSrcUser" Text="sa" Margin="2"/>
                                <Label Grid.Row="1" Grid.Column="2" Content="Pass:" Margin="2,2,0,2"/>
                                <PasswordBox Grid.Row="1" Grid.Column="3" x:Name="pwdSoSrcPass" Margin="2" Width="80"/>
                                <Label Grid.Row="2" Grid.Column="0" Content="Database:"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtSoSrcDb" Text="GPLX_SOGTVT" Margin="2"/>
                                <Button Grid.Row="2" Grid.Column="3" x:Name="btnSoCopyToDst" Content=">" Width="28" Margin="2" Click="BtnSoCopyToDst_Click"/>
                            </Grid>
                        </GroupBox>

                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                            <Button x:Name="btnSoCopyToSrc" Content="&lt;" Width="28" Margin="0,2" Click="BtnSoCopyToSrc_Click"/>
                        </Grid>

                        <GroupBox Grid.Column="2" Header="Đích (Destination)" Padding="6" Margin="4,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Row="0" Grid.Column="0" Content="Server:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtSoDstServer" Text="." Margin="2"/>
                                <Button Grid.Row="0" Grid.Column="2" x:Name="btnSoTestDst" Content="Kiểm tra" Margin="2" Padding="4,0" Click="BtnSoTestDst_Click"/>
                                <Label Grid.Row="1" Grid.Column="0" Content="User:"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtSoDstUser" Text="sa" Margin="2"/>
                                <Label Grid.Row="1" Grid.Column="2" Content="Pass:" Margin="2,2,0,2"/>
                                <PasswordBox Grid.Row="1" Grid.Column="3" x:Name="pwdSoDstPass" Margin="2" Width="80"/>
                                <Label Grid.Row="2" Grid.Column="0" Content="Database:"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtSoDstDb" Text="GPLX_CDB_SOXAYDUNG_v2" Margin="2"/>
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <!-- Script list -->
                    <ListView Grid.Row="1" x:Name="lvScripts" Margin="0,6">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="30">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Script" DisplayMemberBinding="{Binding DisplayName}" Width="250"/>
                                <GridViewColumn Header="Bảng đích" DisplayMemberBinding="{Binding TargetTable}" Width="150"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Run button -->
                    <Button Grid.Row="2" x:Name="btnSoSync" Content="Chạy đồng bộ" Margin="4" Padding="8,4"
                            FontWeight="Bold" HorizontalAlignment="Right" Width="120" Height="30" Click="BtnSoSync_Click"/>
                </Grid>
            </TabItem>

            <TabItem Header="Đồng bộ DB">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Source / Dest groupboxes -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Source -->
                        <GroupBox Grid.Column="0" Header="Nguồn (Source)" Padding="6" Margin="0,0,4,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Server:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtSrcServer" Text="." Margin="2"/>
                                <Button Grid.Row="0" Grid.Column="2" x:Name="btnTestSrc" Content="Kiểm tra" Margin="2" Padding="4,0" Click="BtnTestSrc_Click"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="User:"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtSrcUser" Text="sa" Margin="2"/>
                                <Label Grid.Row="1" Grid.Column="2" Content="Pass:" Margin="2,2,0,2"/>
                                <PasswordBox Grid.Row="1" Grid.Column="3" x:Name="pwdSrcPass" Margin="2" Width="80"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="Database:"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtSrcDb" Text="GPLX_CSDT_64004_Cu" Margin="2"/>
                                <Button Grid.Row="2" Grid.Column="2" x:Name="btnCopyToDst" Content=">" Width="28" Margin="2" Click="BtnCopyToDst_Click"/>
                            </Grid>
                        </GroupBox>

                        <!-- Arrow spacer -->
                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                            <Button x:Name="btnCopyToSrc" Content="&lt;" Width="28" Margin="0,2" Click="BtnCopyToSrc_Click"/>
                        </Grid>

                        <!-- Destination -->
                        <GroupBox Grid.Column="2" Header="Đích (Destination)" Padding="6" Margin="4,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Server:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtDstServer" Text="." Margin="2"/>
                                <Button Grid.Row="0" Grid.Column="2" x:Name="btnTestDst" Content="Kiểm tra" Margin="2" Padding="4,0" Click="BtnTestDst_Click"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="User:"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtDstUser" Text="sa" Margin="2"/>
                                <Label Grid.Row="1" Grid.Column="2" Content="Pass:" Margin="2,2,0,2"/>
                                <PasswordBox Grid.Row="1" Grid.Column="3" x:Name="pwdDstPass" Margin="2" Width="80"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="Database:"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtDstDb" Text="GPLX_CDB_CSDT_v2" Margin="2"/>
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <!-- Table list + controls -->
                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Bảng cần đồng bộ:"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="btnSelectAll" Content="Chọn hết" Margin="2" Padding="4,0" Click="BtnSelectAll_Click"/>
                            <Button x:Name="btnDeselectAll" Content="Bỏ hết" Margin="2" Padding="4,0" Click="BtnDeselectAll_Click"/>
                        </StackPanel>

                        <ListView Grid.Row="1" Grid.ColumnSpan="2" x:Name="lvTables" Margin="0,4">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="30">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Tên bảng" DisplayMemberBinding="{Binding Name}" Width="300"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <!-- Batch size + save/load + sync -->
                        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="Batch size:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtBatchSize" Text="50000" Margin="2" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" x:Name="btnSaveConn" Content="Lưu kết nối" Margin="4,2" Padding="4,0" Click="BtnSaveConn_Click"/>
                            <Button Grid.Column="3" x:Name="btnLoadConn" Content="Tải kết nối" Margin="4,2" Padding="4,0" Click="BtnLoadConn_Click"/>
                            <Button Grid.Column="5" x:Name="btnDbSync" Content="Đồng bộ DB" Margin="2" Padding="8,4" FontWeight="Bold" Click="BtnDbSync_Click"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Log -->
        <TextBox Grid.Row="1" x:Name="txtLog" IsReadOnly="True" AcceptsReturn="True"
                 Margin="0,6,0,0" FontFamily="Consolas" FontSize="10"
                 Background="#1E1E1E" Foreground="LimeGreen" VerticalScrollBarVisibility="Auto"/>
    </Grid>
</Window>
