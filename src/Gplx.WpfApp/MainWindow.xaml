<Window x:Class="Gplx.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Công cụ hỗ trợ chuyển đổi dữ liệu-CSĐT" Width="960" Height="740" MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="Margin" Value="2,4,4,2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderBrush" Value="#B0B0B0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderBrush" Value="#B0B0B0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#B0B0B0"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#F5F5F5"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#DDDDDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ConnLabel" TargetType="Label" BasedOn="{StaticResource FieldLabel}">
            <Setter Property="Width" Value="60"/>
        </Style>
        <Style x:Key="TabHeader" TargetType="TabItem">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F9FF"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="LogBox" TargetType="RichTextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#00FF88"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="StatusBarStyle" TargetType="Border">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="CornerRadius" Value="0,0,3,3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Connection -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Kết nối NGUỒN" Margin="0,0,4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Content="Server:" Style="{StaticResource ConnLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" x:Name="txtSrcServer" Text="." Style="{StaticResource InputBox}"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="User:" Style="{StaticResource ConnLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtSrcUser" Text="sa" Style="{StaticResource InputBox}"/>
                    <Label Grid.Row="1" Grid.Column="2" Content="Mật khẩu:" Style="{StaticResource FieldLabel}" Margin="4,2,0,2"/>
                    <PasswordBox Grid.Row="1" Grid.Column="3" x:Name="pwdSrcPass" Margin="2" HorizontalAlignment="Stretch"/>
                    <Label Grid.Row="2" Grid.Column="0" Content="Database:" Style="{StaticResource ConnLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtSrcDb" Text="GPLX_CSDT_64004_Cu" Style="{StaticResource InputBox}"/>
                    <Button Grid.Row="2" Grid.Column="2" x:Name="btnTestSrc" Content="Kiểm tra" Style="{StaticResource SmallButton}" Click="BtnTestSrc_Click"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" x:Name="txtSrcStatus" Margin="4,2,0,2" VerticalAlignment="Center" FontSize="11"/>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Kết nối ĐÍCH" Margin="4,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Content="Server:" Style="{StaticResource ConnLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" x:Name="txtDstServer" Text="." Style="{StaticResource InputBox}"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="User:" Style="{StaticResource ConnLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtDstUser" Text="sa" Style="{StaticResource InputBox}"/>
                    <Label Grid.Row="1" Grid.Column="2" Content="Mật khẩu:" Style="{StaticResource FieldLabel}" Margin="4,2,0,2"/>
                    <PasswordBox Grid.Row="1" Grid.Column="3" x:Name="pwdDstPass" Margin="2" HorizontalAlignment="Stretch"/>
                    <Label Grid.Row="2" Grid.Column="0" Content="Database:" Style="{StaticResource ConnLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtDstDb" Text="GPLX_CDB_CSDT_v2" Style="{StaticResource InputBox}"/>
                    <Button Grid.Row="2" Grid.Column="2" x:Name="btnTestDst" Content="Kiểm tra" Style="{StaticResource SmallButton}" Click="BtnTestDst_Click"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" x:Name="txtDstStatus" Margin="4,2,0,2" VerticalAlignment="Center" FontSize="11"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Row 1: Transform codes + course + preview -->
        <GroupBox Grid.Row="1" Header="Thông số chuyển đổi" Margin="0,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}">
                    <TextBlock>Mã CSĐT cũ:<Run Foreground="Red" Text="*"/></TextBlock>
                </Label>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtOldCsdt" Style="{StaticResource InputBox}"/>
                <Label Grid.Row="0" Grid.Column="2" Style="{StaticResource FieldLabel}">
                    <TextBlock>→ Mới:<Run Foreground="Red" Text="*"/></TextBlock>
                </Label>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="txtNewCsdt" Style="{StaticResource InputBox}"/>
                <Label Grid.Row="0" Grid.Column="4" Style="{StaticResource FieldLabel}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,4,4,2">Kiểu tạo mã:</Label>
                <StackPanel Grid.Row="0" Grid.Column="5" Orientation="Horizontal">
                    <ComboBox x:Name="cmbCodeMode" Style="{StaticResource InputCombo}" Width="220" SelectedIndex="0" SelectionChanged="CmbCodeMode_SelectionChanged">
                        <ComboBoxItem>Thay thế mã csdt</ComboBoxItem>
                        <ComboBoxItem>Tạo mới theo thông tư 17</ComboBoxItem>
                        <ComboBoxItem>Giữ nguyên</ComboBoxItem>
                    </ComboBox>
                    <Button x:Name="btnGenTT17" Style="{StaticResource SmallButton}" Margin="6,0,0,0" Click="BtnGenTT17_Click" ToolTip="Sinh mã CSĐT theo TT17">Sinh mã</Button>
                </StackPanel>

                <Label Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}">
                    <TextBlock>Mã Sở cũ:<Run Foreground="Red" Text="*"/></TextBlock>
                </Label>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtOldSoCode" Style="{StaticResource InputBox}"/>
                <Label Grid.Row="1" Grid.Column="2" Style="{StaticResource FieldLabel}">
                    <TextBlock>→ Mới:<Run Foreground="Red" Text="*"/></TextBlock>
                </Label>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="txtNewSoCode" Style="{StaticResource InputBox}"/>

                <Label Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}">
                    <TextBlock>Mã khóa học:<Run Foreground="Red" Text="*"/></TextBlock>
                </Label>
                <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" x:Name="cmbCourseCode"
                          IsEditable="True" StaysOpenOnEdit="True" IsTextSearchEnabled="False"
                          Style="{StaticResource InputCombo}"
                          KeyUp="CmbCourseCode_KeyUp"
                          SelectionChanged="CmbCourseCode_SelectionChanged"
                          DropDownOpened="CmbCourseCode_DropDownOpened"/>
                <!-- Responsive layout for new course code and name -->
                <Grid Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="3" Margin="4,2" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <TextBox x:Name="txtNewCourseCode" FontSize="12" Foreground="#0078D4" FontWeight="SemiBold" Width="220" Style="{StaticResource InputBox}"/>
                    </StackPanel>
                    <TextBox Grid.Column="1" x:Name="txtNewCourseName" FontSize="11" Foreground="#666666" Margin="8,0,0,0" Style="{StaticResource InputBox}" HorizontalAlignment="Stretch"/>
                    <TextBlock Grid.Column="2" x:Name="txtExistLink" Visibility="Collapsed" Margin="6,0,0,0"
                               VerticalAlignment="Center" FontSize="11" Cursor="Hand">
                        <Hyperlink x:Name="lnkExist" RequestNavigate="LnkExist_RequestNavigate"
                                   NavigateUri="about:blank">
                            <Run Text="đã tồn tại - nhấn vào để xem"/>
                        </Hyperlink>
                    </TextBlock>
                </Grid>
                <Button Grid.Row="2" Grid.Column="7" x:Name="btnPreview" Style="{StaticResource PrimaryButton}" Click="BtnPreview_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12,4.5 C7,4.5 2.73,7.61 1,12 C2.73,16.39 7,19.5 12,19.5 C17,19.5 21.27,16.39 23,12 C21.27,7.61 17,4.5 12,4.5 Z M12,17 C9.24,17 7,14.76 7,12 C7,9.24 9.24,7 12,7 C14.76,7 17,9.24 17,12 C17,14.76 14.76,17 12,17 Z M12,9 C10.34,9 9,10.34 9,12 C9,13.66 10.34,15 12,15 C13.66,15 15,13.66 15,12 C15,10.34 13.66,9 12,9 Z"
                              Fill="White" Stretch="Uniform" Width="14" Height="14" Margin="0,0,4,0"/>
                        <TextBlock Text="Xem trước" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </GroupBox>

        <!-- Row 2: Preview tabs -->
        <TabControl Grid.Row="2" Margin="0,2,0,4">
            <TabItem x:Name="tabNguoiLX" Header="Học viên (NguoiLX)" Style="{StaticResource TabHeader}">
                <DataGrid x:Name="dgvNguoiLX"/>
            </TabItem>
            <TabItem x:Name="tabBaoCaoI" Header="Báo cáo I (BaoCaoI)" Style="{StaticResource TabHeader}">
                <DataGrid x:Name="dgvBaoCaoI"/>
            </TabItem>
            <TabItem x:Name="tabBaoCaoII" Header="Báo cáo II (BaoCaoII)" Style="{StaticResource TabHeader}">
                <DataGrid x:Name="dgvBaoCaoII"/>
            </TabItem>
        </TabControl>

        <!-- Row 3: Toolbar -->
        <Grid Grid.Row="3" Margin="0,0,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="130"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Content="Batch:" VerticalAlignment="Center" Margin="2,0" FontSize="12"/>
            <TextBox Grid.Column="1" x:Name="txtBatchSize" Text="50000" Style="{StaticResource InputBox}" VerticalContentAlignment="Center"/>
            <ProgressBar Grid.Column="2" x:Name="progressBar" Margin="10,0" Height="16"
                         Visibility="Collapsed" IsIndeterminate="True" Foreground="#0078D4" Background="#E0E0E0"/>
            <Button Grid.Column="3" x:Name="btnDbSync" Style="{StaticResource PrimaryButton}" Click="BtnDbSync_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="▶" Margin="0,0,4,0"/>
                    <TextBlock Text="Thực hiện" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Row 4: Log -->
        <Grid Grid.Row="4" Margin="0,0,0,4">
            <RichTextBox x:Name="txtLog" Style="{StaticResource LogBox}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,4,10,0">
                <TextBlock x:Name="txtCopyStatus" Text="đã sao chép log"
                           Foreground="#00CC66" FontSize="11" VerticalAlignment="Center"
                           Visibility="Collapsed" Margin="0,0,6,0"/>
                <Button x:Name="btnCopyLog" Style="{StaticResource SmallButton}"
                        Padding="6,2" Click="BtnCopyLog_Click" ToolTip="Sao chép log">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M4,2 L4,12 L14,12 L14,2 L4,2 Z M2,4 L2,14 L12,14 L12,12 L4,12 L4,4 L2,4 Z"
                              Fill="#555555" Stretch="Uniform" Width="12" Height="12" Margin="0,0,4,0"/>
                        <TextBlock Text="Sao chép" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Row 5: Status bar -->
        <Border Grid.Row="5" Style="{StaticResource StatusBarStyle}">
            <TextBlock x:Name="txtStatus" Foreground="White" FontSize="11">Sẵn sàng</TextBlock>
        </Border>
    </Grid>
</Window>
