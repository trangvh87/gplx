<Window x:Class="Gplx.SoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gplx - Đồng bộ Sở" Width="920" Height="720"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Connection -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Nguồn (Source)" Padding="6" Margin="0,0,4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Content="Server:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtSrcServer" Text="." Margin="2"/>
                    <Button Grid.Row="0" Grid.Column="2" x:Name="btnTestSrc" Content="Kiểm tra" Margin="2" Padding="4,0" Click="BtnTestSrc_Click"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="User:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtSrcUser" Text="sa" Margin="2"/>
                    <Label Grid.Row="1" Grid.Column="2" Content="Pass:" Margin="2,2,0,2"/>
                    <PasswordBox Grid.Row="1" Grid.Column="3" x:Name="pwdSrcPass" Margin="2" Width="80"/>
                    <Label Grid.Row="2" Grid.Column="0" Content="Database:"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtSrcDb" Text="GPLX_SOGTVT" Margin="2"/>
                    <Button Grid.Row="2" Grid.Column="3" x:Name="btnCopyToDst" Content=">" Width="28" Margin="2" Click="BtnCopyToDst_Click"/>
                </Grid>
            </GroupBox>

            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                <Button x:Name="btnCopyToSrc" Content="&lt;" Width="28" Margin="0,2" Click="BtnCopyToSrc_Click"/>
            </Grid>

            <GroupBox Grid.Column="2" Header="Đích (Destination)" Padding="6" Margin="4,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Content="Server:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtDstServer" Text="." Margin="2"/>
                    <Button Grid.Row="0" Grid.Column="2" x:Name="btnTestDst" Content="Kiểm tra" Margin="2" Padding="4,0" Click="BtnTestDst_Click"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="User:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtDstUser" Text="sa" Margin="2"/>
                    <Label Grid.Row="1" Grid.Column="2" Content="Pass:" Margin="2,2,0,2"/>
                    <PasswordBox Grid.Row="1" Grid.Column="3" x:Name="pwdDstPass" Margin="2" Width="80"/>
                    <Label Grid.Row="2" Grid.Column="0" Content="Database:"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtDstDb" Text="GPLX_CDB_SOXAYDUNG_v2" Margin="2"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Row 1: Transform codes + course + preview -->
        <GroupBox Grid.Row="1" Header="Chuyển đổi mã &amp; tùy chọn" Padding="6" Margin="0,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Mã Sở cũ:" Margin="2"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtOldSoCode" Margin="2"/>
                <Label Grid.Row="0" Grid.Column="2" Content="→ Mới:" Margin="2"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="txtNewSoCode" Margin="2"/>

                <Label Grid.Row="1" Grid.Column="0" Content="Mã khóa học:" Margin="2"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" x:Name="txtCourseCode" Margin="2"/>
                <Button Grid.Row="1" Grid.Column="7" x:Name="btnPreview" Content="Xem trước" Margin="2" Padding="8,2" Click="BtnPreview_Click"/>
            </Grid>
        </GroupBox>

        <!-- Row 2: Preview tabs -->
        <TabControl Grid.Row="2" Margin="0,0,0,6">
            <TabItem Header="Học viên (NguoiLX)">
                <DataGrid x:Name="dgvNguoiLX" AutoGenerateColumns="True" IsReadOnly="True"
                          CanUserSortColumns="True" VerticalScrollBarVisibility="Auto"/>
            </TabItem>
            <TabItem Header="Báo cáo I (BaoCaoI)">
                <DataGrid x:Name="dgvBaoCaoI" AutoGenerateColumns="True" IsReadOnly="True"
                          CanUserSortColumns="True" VerticalScrollBarVisibility="Auto"/>
            </TabItem>
            <TabItem Header="Báo cáo II (BaoCaoII)">
                <DataGrid x:Name="dgvBaoCaoII" AutoGenerateColumns="True" IsReadOnly="True"
                          CanUserSortColumns="True" VerticalScrollBarVisibility="Auto"/>
            </TabItem>
        </TabControl>

        <!-- Row 3: Toolbar -->
        <Grid Grid.Row="3" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="130"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="btnSaveConn" Content="Lưu kết nối" Margin="2" Padding="6,2" Click="BtnSaveConn_Click"/>
            <Button Grid.Column="1" x:Name="btnLoadConn" Content="Tải kết nối" Margin="2" Padding="6,2" Click="BtnLoadConn_Click"/>
            <Button Grid.Column="3" x:Name="btnSync" Content="Đồng bộ Sở" Margin="2" Padding="8,4"
                    FontWeight="Bold" FontSize="14" Height="30" Click="BtnSync_Click"/>
        </Grid>

        <!-- Row 4: Log -->
        <TextBox Grid.Row="4" x:Name="txtLog" IsReadOnly="True" AcceptsReturn="True"
                 FontFamily="Consolas" FontSize="10"
                 Background="#1E1E1E" Foreground="LimeGreen" VerticalScrollBarVisibility="Auto"/>
    </Grid>
</Window>
